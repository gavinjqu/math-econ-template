\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{homework}[2026/07/04 v1.1 Homework problems + toggleable solutions]

% =====================================================================
%  homework.sty  --  problem/solution scaffolding for problem sets.
%
%  Solutions live inside \begin{solution}...\end{solution} in a shared
%  "content" file.  Two thin wrapper files decide whether they print:
%    - the assignment wrapper leaves solutions hidden (default)
%    - the answer-key wrapper calls \showsolutions
%  => one source of truth, two separate PDFs.
% =====================================================================

\RequirePackage{etoolbox}
\RequirePackage{enumitem}
\RequirePackage{environ}   % robust body capture for the solution toggle

% ---- Solution visibility (hidden by default; wrapper flips it) ----
\newif\ifshowsolutions
\showsolutionsfalse
\newcommand{\showsolutions}{\showsolutionstrue}
\newcommand{\hidesolutions}{\showsolutionsfalse}

% ---- Assignment metadata ----
\def\hw@course{}\def\hw@number{}\def\hw@student{}\def\hw@due{}
\newcommand{\course}[1]{\def\hw@course{#1}}
\newcommand{\hwnumber}[1]{\def\hw@number{#1}}
\newcommand{\hwstudent}[1]{\def\hw@student{#1}}
\newcommand{\hwdue}[1]{\def\hw@due{#1}}

\newcommand{\makehwheader}{%
  \begin{center}%
    {\large\bfseries \hw@course}\\[2pt]%
    {\bfseries Problem Set \hw@number\ifshowsolutions\ --- Solutions\fi}%
    \ifdefempty{\hw@student}{}{\\[2pt]\hw@student}%
    \ifdefempty{\hw@due}{}{\quad(Due: \hw@due)}%
  \end{center}%
  \vspace{0.75em}%
}

% ---- Problem environment: auto-numbered, optional short title ----
\newcounter{hwproblem}
\newenvironment{problem}[1][]{%
  \medskip\par\refstepcounter{hwproblem}%
  \noindent\textbf{Problem \thehwproblem}%
  \ifstrempty{#1}{}{ \textbf{(#1)}}\textbf{.}\ %
}{\par\medskip}

% ---- Solution environment: typeset only when \showsolutions is set. ----
% environ captures the body as \BODY; when solutions are hidden we never
% emit \BODY, so its content is discarded (and never executed). Unlike the
% comment package, this imposes no line-break rules on \begin/\end.
\NewEnviron{solution}{%
  \ifshowsolutions
    \par\smallskip\noindent\textit{Solution.}\ \BODY\par\smallskip
  \fi
}

\endinput
